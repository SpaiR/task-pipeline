# macOS
.DS_Store

# Serena
.serena/cache/
.serena/project.local.yml

# Task pipeline working artifacts.
# Dogfooding exception: in consumer projects the intake skills' inline Step 0 setup
# (to-task/to-plan/to-roadmap/to-spec) excludes `.task/` via `.git/info/exclude`
# (per-clone) — see the "invisibility" invariant in CLAUDE.md.
# Here, in the plugin's own repo, we ignore it through shared .gitignore so every
# contributor inherits the exclusion without repeating the per-clone setup.
.task/

# self-audit ratchet baseline (runtime metrics, per-clone)
.claude/.audit-baseline.json

# self-improve ratchet baseline (runtime metrics, per-clone)
.claude/.improve-baseline.json

# Docs site (VitePress) build artifacts and deps
website/node_modules/
website/.vitepress/dist/
website/.vitepress/cache/

# Editor
.idea/
.vscode/
